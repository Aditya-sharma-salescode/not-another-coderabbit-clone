# === Required ===
ANTHROPIC_API_KEY=sk-ant-...
GITHUB_TOKEN=ghp_...

# === Jira (optional — reviewer works without it) ===
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=bot@your-org.com
JIRA_API_TOKEN=...

# === Figma (optional) ===
FIGMA_ACCESS_TOKEN=figd_...

# === GitHub repo context (set by CI or CLI) ===
GITHUB_REPO=your-org/channelkart-flutter
PR_NUMBER=
BASE_SHA=
HEAD_SHA=
BRANCH_NAME=

# === Registry paths ===
REGISTRY_PATH=registry

# === Tokens for write-back (used by GitHub Actions) ===
REVIEWER_REPO_TOKEN=ghp_...
REGISTRY_WRITE_TOKEN=ghp_...
